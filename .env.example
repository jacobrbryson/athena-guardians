# Guardians frontend — environment variables.
# Vite inlines VITE_* vars at BUILD time. For Cloud Run, pass them as Docker
# build args (see cloudbuild.yaml), not as Cloud Run runtime env vars.

# Base URL of the proxy_service (auth + API + WebSocket).
#   - Local dev: leave EMPTY. The Vite dev server proxies /auth, /api and /ws
#     to http://localhost:8080, so the session cookie stays same-origin.
#   - Production: the public proxy_service URL, e.g.
#     https://athena-proxy-api-12367074465.us-central1.run.app
VITE_PROXY_BASE=

# Where the Unity WebGL build lives (the Build/ directory sits under this path).
# Defaults to the same-origin '/unity' path, which both the Vite dev server and
# the production server.js reverse-proxy to the GCS bucket — so the browser
# loads the ~126MB Unity assets same-origin (no CORS) without copying them in.
# Override only if you have a CORS-enabled CDN/bucket to point at directly.
VITE_UNITY_ASSET_BASE=/unity

# Bucket ROOT (containing the unity/ folder) that the /unity path is
# reverse-proxied to. Used by both the Vite dev server and server.js; the
# '/unity/...' request path is preserved when proxying.
UNITY_UPSTREAM=https://storage.googleapis.com/assets-athena-app

# Local dev only: where the Vite dev server forwards /auth, /api, /ws.
# Defaults to http://localhost:8080 (the proxy_service).
VITE_DEV_PROXY_TARGET=http://localhost:8080
